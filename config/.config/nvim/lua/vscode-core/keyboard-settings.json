    "command": "workbench.action.terminal.focusAtIndex9"
  },
  {
    "key": "alt+t",
    "command": "workbench.action.terminal.new",
    "when": "neovim.mode != 'insert'"
  },
  {
    "key": "alt+w",
    "command": "workbench.action.terminal.kill",
    "when": "neovim.mode != 'insert'"
  },
  {
    "key": "cmd+e",
    "command": "workbench.view.explorer"
  },
  {
    "key": "cmd+j",
    "command": "workbench.action.terminal.toggleTerminal"
  },
  {
    "key": "cmd+i",
    "command": "composerMode.agent"
  },
  {
    "key": "alt+g alt+g",
    "command": "workbench.view.scm",
    "when": "workbench.scm.active"
  },
  {
    "key": "ctrl+shift+g",
    "command": "-workbench.view.scm",
    "when": "workbench.scm.active"
  },
  {
    "key": "alt+g alt+m",
    "command": "cursor.generateGitCommitMessage"
  },
  {
    "key": "alt+g alt+p",
    "command": "git.push"
  },
  {
    "key": "alt+g alt+l",
    "command": "git.pull"
  },
  {
    "key": "shift+cmd+h",
    "command": "-workbench.action.replaceInFiles"
  },
  {
    "key": "cmd+p",
    "command": "workbench.action.quickOpen"
  },
  {
    "key": "alt+g alt+c",
    "command": "git.commit"
  },
  {
    "key": "alt+f alt+r",
    "command": "workbench.action.replaceInFiles"
  },
  {
    "key": "alt+f alt+d",
    "command": "periscope.search"
  },
  {
    "key": "alt+f alt+f",
    "command": "search-preview.quickOpenWithPreview"
  },
  {
    "key": "shift+cmd+r",
    "command": "-workbench.action.reloadWindow",
    "when": "isDevelopment"
  },
  {
    "key": "shift+cmd+r",
    "command": "workbench.action.reloadWindow"
  },
  {
    "key": "ctrl+j",
    "command": "selectNextSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
  },
  {
    "key": "ctrl+k",
    "command": "selectPrevSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
  },
  {
    "key": "cmd+shift+u",
    "command": "editor.action.marker.prevInFiles",
    "when": "editorFocus"
  },
  {
    "key": "cmd+u",
    "command": "editor.action.marker.nextInFiles",
    "when": "editorFocus"
  },
  {
    "key": "ctrl+j",
    "command": "selectNextCodeAction",
    "when": "codeActionMenuVisible"
  },
  {
    "key": "ctrl+down",
    "command": "selectNextCodeAction",
    "when": "codeActionMenuVisible"
  },
  {
    "key": "ctrl+k",
    "command": "selectPrevCodeAction",
    "when": "codeActionMenuVisible"
  },
  {
    "key": "ctrl+up",
    "command": "selectPrevCodeAction",
    "when": "codeActionMenuVisible"
  },
  {
    "key": "ctrl+shift+l",
    "command": "workbench.action.nextEditorInGroup"
  },
  {
    "key": "cmd+r alt+cmd+right",
    "command": "-workbench.action.nextEditorInGroup"
  },
  {
    "key": "ctrl+shift+h",
    "command": "workbench.action.previousEditorInGroup"
  },
  {
    "key": "cmd+r alt+cmd+left",
    "command": "-workbench.action.previousEditorInGroup"
  },
  {
    "key": "cmd+shift+f",
    "command": "-workbench.action.findInFiles",
    "when": "neovim.mode != 'insert'"
  },
  {
    "key": "alt+j",
    "command": "list.focusDown",
    "when": "!editorFocus"
  },
  {
    "key": "alt+k",
    "command": "list.focusUp",
    "when": "!editorFocus"
},
{
    "key": "alt+cmd+s",
    "command": "workbench.action.toggleUnifiedSidebarFromKeyboard",
    "when": "cursor.agentIdeUnification.enabled == true && !isAuxiliaryWindowFocusedContext"
},
{
    "key": "shift+enter",
    "command": "workbench.action.terminal.sendSequence",
    "args": {
        "text": "\u001b\r"
    },
    "when": "terminalFocus"
}
]

